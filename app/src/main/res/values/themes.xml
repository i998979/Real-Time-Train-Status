<resources>

    <style name="Theme.TransitApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>

        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/bar_bright</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:statusBarColor">@color/bar_bright</item>
        <item name="android:navigationBarColor">@color/bar_bright</item>

        <item name="elevationOverlayEnabled">false</item>
    </style>

    <style name="TabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="TabText.Selected" parent="TabText">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="OptionButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:backgroundTint">?attr/colorOnSurfaceInverse</item>
        <item name="cornerRadius">8dp</item>
        <item name="rippleColor">?attr/colorControlHighlight</item>
    </style>

    <style name="RadioButtonStyle" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:drawableStart">@drawable/selector_check_circle</item>
        <item name="android:drawableTint">@color/selector_radio_tint</item>
        <item name="android:textColor">@color/button_green</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:button">@null</item>
        <item name="useMaterialThemeColors">false</item>
        <item name="android:drawablePadding">16dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="GreenAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">?attr/colorOnSurfaceVariant</item>
        <item name="buttonBarPositiveButtonStyle">@style/GreenAlertButtonStyle</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="GreenAlertButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/button_green</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>